# 이 파일을 복사해서 ".env" 로 저장한 뒤 값을 채우세요.
# (demo 모드면 아무 값도 안 채워도 그냥 돌아갑니다.)

# demo = 가짜 데이터로 전체 흐름 확인 / live = 실제 데이터
MODE=demo

# ----- eBay 공식 API 키 (무료, developer.ebay.com 에서 발급) -----
# live 모드에서만 필요. Application(Production) 의 App ID / Cert ID 입니다.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_US
SEARCH_QUERY=pokemon psa10
SEARCH_LIMIT=100
# 거래 조건: 소재지 국가(US=미국만, 빈값=전체) + 최대 배송비(USD) + 최소 입찰 수(이 값 미만 제외)
ITEM_LOCATION_COUNTRY=US
MAX_SHIPPING=10
MIN_BID_COUNT=11
# 예산 상한(현재가 이하만, 0=무제한) + 시세 하한(PSA10 이상만, 0=무제한)
MAX_BID=500
MIN_MARKET_VALUE=50
# 예상수익(USD) 하한: 현재가 기준 예상수익이 이 값 미만이면 제외 (0=무제한)
MIN_PROFIT=15
# 입찰 적어도 ROI 이 값 이상이면 예외 표시(🔥스틸). 0.5=50%
HIGH_ROI_OVERRIDE=0.5
# 제목에 이 단어 있으면 제외 (쉼표 구분)
EXCLUDE_KEYWORDS=lot,bulk,proxy,custom,jumbo,oversized,sticker,reprint,fake,read desc

# ----- PriceCharting (Legendary 구독 $59/년) -----
# live 모드: 매일 받은 전체 CSV 파일 경로를 지정하세요.
# 예: C:\psa-tool\data\pricecharting_full.csv
PC_CSV_PATH=
PC_TOKEN=
PC_PRICE_IN_PENNIES=true

# ----- eBay 실낙찰가 자동 조회 (130point/PSA APR 자동화) -----
# demo / pokemonpricetracker / ebay_insights
SOLD_PROVIDER=demo
SOLD_DAYS=90
MIN_SOLD_COUNT=3
# PokemonPriceTracker (https://www.pokemonpricetracker.com, ~$10/월) 구독 후 키 입력
PPT_API_KEY=

# ----- 슬랩 라벨 OCR (선택, 의심 카드만 비전 분석으로 매칭 보정) -----
# 키 채우면 활성: 셀러가 번호/세트를 잘못 입력한 카드의 PSA 슬랩 라벨을 읽어
# #번호·등급으로 재매칭. Anthropic API 키(console.anthropic.com). 의심카드만 호출=저비용.
VISION_API_KEY=
VISION_MODEL=claude-haiku-4-5-20251001
VISION_MAX_PER_RUN=30

# ----- 가치 판단 파라미터 -----
# 시세 위험 보정 (하락추세/낮은신뢰도면 시세 할인)
TREND_DOWN_FACTOR=0.90
LOW_CONF_FACTOR=0.92
DROP_FLAG_RATIO=0.7
RISKY_ALERT_ROI=0.6

# ----- Gixen 자동 스나이핑 (선택) -----
# 채우면 대시보드의 "🅖 Gixen 자동등록" 버튼이 활성화됨(클릭=권장입찰가로 스나이프 등록).
# username/password = gixen.com 로그인 정보. 비워두면 기존처럼 번호·입찰가 복붙 안내만 나옴.
GIXEN_USERNAME=
GIXEN_PASSWORD=
GIXEN_BIDOFFSET=6

# 텔레그램 알림 (선택)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFY_WINDOW_HOURS=12

RESELL_FEE_RATE=0.13
DEFAULT_SHIPPING=5.0
MIN_ROI=0.15
MIN_MATCH_SCORE=70
